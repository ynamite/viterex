(3,	'page-intro',	'Page Intro',	'<section class=\"mb-clamp-12-20\">\n	<?php if (REX_VALUE[1]): ?>\n		<p class=\"font-semibold text-brand-cyan text-sm uppercase tracking-widest\">\n			REX_VALUE[1]\n		</p>\n	<?php endif ?>\n	<h1 class=\"mt-4 font-extrabold text-fg leading-[1.05] tracking-tight clamp-[text,4xl,7xl]\">\n		REX_VALUE[2]\n	</h1>\n	<?php if (REX_VALUE[3]): ?>\n		<p class=\"mt-6 max-w-prose text-muted clamp-[text,base,xl]\">\n			REX_VALUE[3]\n		</p>\n	<?php endif ?>\n</section>\n',	'<div class=\"rex-form-group form-group\">\n	<label>Eyebrow (optional)</label>\n	<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[1]\" value=\"REX_VALUE[1]\" placeholder=\"z. B. Funktionen · Live Reload\">\n</div>\n\n<div class=\"rex-form-group form-group\">\n	<label>Titel (h1)</label>\n	<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[2]\" value=\"REX_VALUE[2]\">\n</div>\n\n<div class=\"rex-form-group form-group\">\n	<label>Lead</label>\n	<textarea class=\"form-control\" name=\"REX_INPUT_VALUE[3]\" rows=\"3\">REX_VALUE[3]</textarea>\n</div>\n',	'2026-04-30 21:26:44',	'admin',	'2026-04-30 21:34:10',	'console',	NULL,	0),
(4,	'card-grid',	'Card Grid',	'<section class=\"mb-clamp-12-20\"<?= REX_VALUE[1] ? \' id=\"\' . REX_VALUE[1] . \'\"\' : \'\' ?>>\n	<?php if (REX_VALUE[2]): ?>\n		<h2 class=\"mb-4 font-extrabold text-fg clamp-[text,2xl,4xl]\">REX_VALUE[2]</h2>\n	<?php endif ?>\n	<?php if (REX_VALUE[3]): ?>\n		<p class=\"mb-10 max-w-prose text-muted\">REX_VALUE[3]</p>\n	<?php endif ?>\n	<ul class=\"grid gap-6 sm:grid-cols-2 lg:grid-cols-3\">\n		<?php\n		$cards = [\n			[\'title\' => REX_VALUE[4], \'desc\' => REX_VALUE[5], \'linkId\' => REX_LINK[1]],\n			[\'title\' => REX_VALUE[6], \'desc\' => REX_VALUE[7], \'linkId\' => REX_LINK[2]],\n			[\'title\' => REX_VALUE[8], \'desc\' => REX_VALUE[9], \'linkId\' => REX_LINK[3]],\n		];\n		foreach ($cards as $card):\n			if ($card[\'title\'] === \'\') continue;\n			$href = $card[\'linkId\'] ? rex_getUrl($card[\'linkId\']) : null;\n			$tag  = $href ? \'a\' : \'div\';\n		?>\n			<li>\n				<<?= $tag ?><?= $href ? \' href=\"\' . rex_escape($href) . \'\"\' : \'\' ?>\n					class=\"group flex flex-col gap-2 bg-surface p-6 border border-white/10 rounded-xl h-full <?= $href ? \'transition-colors hover:border-brand-cyan/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan\' : \'\' ?>\">\n					<span class=\"font-extrabold text-fg text-xl\"><?= $card[\'title\'] ?></span>\n					<?php if ($card[\'desc\']): ?>\n						<span class=\"text-muted\"><?= $card[\'desc\'] ?></span>\n					<?php endif ?>\n					<?php if ($href): ?>\n						<span class=\"inline-flex items-center gap-1 mt-auto pt-3 text-brand-cyan text-sm\">\n							Mehr erfahren\n							<span class=\"size-4 motion-safe:transition-transform group-hover:translate-x-1 icon-[lucide--arrow-right]\" aria-hidden=\"true\"></span>\n						</span>\n					<?php endif ?>\n				</<?= $tag ?>>\n			</li>\n		<?php endforeach ?>\n	</ul>\n</section>\n',	'<fieldset>\n	<legend>Sektion</legend>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Anker-ID (optional)</label>\n		<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[1]\" value=\"REX_VALUE[1]\" placeholder=\"z. B. features\">\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Section-Titel (h2, optional)</label>\n		<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[2]\" value=\"REX_VALUE[2]\">\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Section-Lead (optional)</label>\n		<textarea class=\"form-control\" name=\"REX_INPUT_VALUE[3]\" rows=\"2\">REX_VALUE[3]</textarea>\n	</div>\n</fieldset>\n\n<fieldset>\n	<legend>Karte 1</legend>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Titel</label>\n		<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[4]\" value=\"REX_VALUE[4]\">\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Beschreibung</label>\n		<textarea class=\"form-control\" name=\"REX_INPUT_VALUE[5]\" rows=\"2\">REX_VALUE[5]</textarea>\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Link auf Artikel (optional)</label>\n		REX_LINK[id=1 widget=1]\n	</div>\n</fieldset>\n\n<fieldset>\n	<legend>Karte 2</legend>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Titel</label>\n		<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[6]\" value=\"REX_VALUE[6]\">\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Beschreibung</label>\n		<textarea class=\"form-control\" name=\"REX_INPUT_VALUE[7]\" rows=\"2\">REX_VALUE[7]</textarea>\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Link auf Artikel (optional)</label>\n		REX_LINK[id=2 widget=1]\n	</div>\n</fieldset>\n\n<fieldset>\n	<legend>Karte 3 (optional)</legend>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Titel</label>\n		<input class=\"form-control\" type=\"text\" name=\"REX_INPUT_VALUE[8]\" value=\"REX_VALUE[8]\">\n	</div>\n\n	<div class=\"rex-form-group form-group\">\n		<label>Beschreibung</label>\n		<textarea class=\"form-control\" name=\"REX_INPUT_VALUE[9]\" rows=\"2\">REX_VALUE[