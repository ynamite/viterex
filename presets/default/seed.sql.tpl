(5,	'meta',	'Meta',	'<meta charset=\"utf-8\" />\n<?php $seoTags = (new rex_yrewrite_seo())->getTags(); ?>\n<?= $seoTags ?>\n<?php if (!str_contains($seoTags, \'<title>\')): ?>\n    <title>ViteRex — Supercharged REDAXO frontend development with Vite 8</title>\n<?php endif ?>\n\n<link rel=\"icon\" type=\"image/png\" href=\"/favicon-96x96.png\" sizes=\"96x96\" />\n<link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" />\n<link rel=\"shortcut icon\" href=\"/favicon.ico\" />\n<link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon.png\" />\n<meta name=\"apple-mobile-web-app-title\" content=\"ViteRex\" />\n<link rel=\"manifest\" href=\"/site.webmanifest\" />\n\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<meta name=\"generator\" content=\"REDAXO CMS\" />\n<meta name=\"theme-color\" content=\"#070712\" />\n\n<style>\n    @view-transition {\n        navigation: auto;\n    }\n</style>\n\nREX_VITE',	0,	'2026-03-06 17:22:39',	'admin',	'2026-05-01 10:39:26',	'console',	'{\"ctype\":[],\"modules\":{\"1\":{\"all\":\"1\"}},\"categories\":{\"all\":\"1\"}}',	0),
(7,	'footer',	'* Footer',	'<?php\n// Hardcoded article IDs — seeded one-shot during initial setup.\n// Datenschutz=3 (pre-existing), Impressum=11.\n// Plain locals (not file-scope const) — REDAXO may render the same template twice\n// per request (e.g. block_peek previews), and `const` at file scope would fatal on\n// the second include with \"Cannot redeclare constant\".\n$datenschutz = rex_article::get(3);\n$impressum   = rex_article::get(11);\n?>\n<footer class=\"bg-surface mt-clamp-16-32 border-white/10 border-t\">\n	<div class=\"flex md:flex-row flex-col md:justify-between md:items-center gap-6 mx-auto px-6 sm:px-8 py-8 max-w-7xl\"\n		style=\"padding-bottom: max(2rem, env(safe-area-inset-bottom));\">\n		<p class=\"text-muted text-sm\">\n			© <?= date(\'Y\') ?> ViteRex · Made by\n			<a href=\"https://www.massif.ch\" rel=\"noopener\" class=\"text-brand-cyan hover:underline\">massif.ch</a>\n		</p>\n		<nav aria-label=\"Rechtliches\" class=\"flex items-center gap-6 text-sm\">\n			<?php if ($datenschutz): ?>\n				<a href=\"<?= $datenschutz->getUrl() ?>\" class=\"rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan text-muted hover:text-fg transition-colors\">Datenschutz</a>\n			<?php endif ?>\n			<?php if ($impressum): ?>\n				<a href=\"<?= $impressum->getUrl() ?>\" class=\"rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan text-muted hover:text-fg transition-colors\">Impressum</a>\n			<?php endif ?>\n			<a href=\"https://github.com/ynamite/viterex_addon\" rel=\"noopener\" aria-label=\"ViteRex on GitHub\"\n				class=\"inline-flex justify-center items-center border border-white/10 hover:border-white/20 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan size-9 text-muted hover:text-fg transition-colors\">\n				<span class=\"size-5 icon-[lucide--github]\" aria-hidden=\"true\"></span>\n			</a>\n		</nav>\n	</div>\n</footer>',	0,	'2026-03-06 17:22:39',	'admin',	'2026-05-07 08:21:06',	'console',	'{\"ctype\":[],\"modules\":{\"1\":{\"all\":\"1\"}},\"categories\":{\"all\":\"1\"}}',	0),
(8,	'header',	'* Header',	'<?php\n\nuse Ynamite\\ViteRex\\Assets;\n\nAssets::inline(\'img/viterex.svg\');\n?>\n<header class=\"z-40 relative clamp-[h,20,25]\">\n	<div class=\"top-0 after:-z-10 fixed after:absolute after:inset-0 flex justify-center items-center gap-6 after:bg-bg/85 after:backdrop-blur border-white/10 border-b w-full\">\n		<div class=\"flex justify-between items-center mx-auto px-6 sm:px-8 py-4 w-full max-w-7xl\">\n			<a href=\"/\" rel=\"home\" class=\"group flex items-center gap-3\">\n				<span class=\"block [&_svg]:block size-12 [&_svg]:size-full md:size-16 shrink-0\" aria-hidden=\"true\">\n					<?= Assets::inline(\'img/viterex.svg\') ?>\n				</span>\n				<span class=\"flex flex-col leading-tight\">\n					<span class=\"w-fit font-extrabold text-gradient-brand text-3xl md:text-4xl tracking-tight\">ViteRex</span>\n					<span class=\"hidden sm:block font-medium text-[11px] text-muted uppercase tracking-widest\">\n						Supercharged <span class=\"text-brand-magenta\">REDAXO</span> frontend with <span class=\"text-brand-cyan\">Vite 8</span>\n					</span>\n				</span>\n			</a>\n			REX_TEMPLATE[key=\"menu\"]\n		</div>\n	</div>\n</header>',	0,	'2026-03-06 17:22:39',	'admin',	'2026-05-07 08:23:05',	'console',	'{\"ctype\":[],\"modules\":{\"1\":{\"all\":\"1\"}},\"categories\":{\"all\":\"1\"}}',	0),
(12,	'menu',	'* Menu',	'<?php\n$rootCategories = rex_category::getRootCategories();\n$currentArticle = rex_article::getCurrent();\n$currentId = $currentArticle?->getId();\n$currentAncestorIds = $currentArticle ? $currentArticle->getPathAsArray() : [];\n\n// \"active branch\" = current article IS this category, OR this category is an ancestor of current article\n$isActiveBranch = static fn(rex_category $cat): bool =>\n$cat->getId() === $currentId || in_array($cat->getId(), $currentAncestorIds, true);\n\n// \"exact page\" = the current article IS this category\'s start article (used for child highlighting)\n$isExactPage = static fn(rex_category $cat): bool => $cat->getId() === $currentId;\n?>\n<!-- Desktop -->\n<nav\n  aria-label=\"Desktop Hauptmenü\" class=\"hidden md:flex items-center gap-3\">\n  <!-- DESKTOP nav (md+) -->\n  <ul class=\"flex items-center gap-x-7 font-medium text-sm\">\n    <?php foreach ($rootCategories as $top):\n      $children = $top->getChildren();\n      $active = $isActiveBranch($top);\n    ?>\n      <li class=\"relative py-2\"\n        <?= $children ? \'x-data=\"{ openSub: false }\" @mouseenter=\"openSub = true\" @mouseleave=\"openSub = false\" @focusin=\"openSub = true\" @focusout.away=\"openSub = false\"\' : \'\' ?>>\n        <a href=\"<?= rex_escape($top->getUrl()) ?>\"\n          class=\"inline-flex items-center gap-1 py-2 transition-colors <?= $active ? \'text-brand-cyan\' : \'text-muted hover:text-fg\' ?> focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan rounded\"\n          <?= $active ? \'aria-current=\"page\"\' : \'\' ?>\n          <?= $children ? \':aria-expanded=\"openSub\"\' : \'\' ?>>\n          <span><?= rex_escape($top->getName()) ?></span>\n          <?php if ($children): ?>\n            <span class=\"size-4 motion-safe:transition-transform icon-[lucide--chevron-down]\" :class=\"openSub && \'rotate-180\'\" aria-hidden=\"true\"></span>\n          <?php endif ?>\n        </a>\n        <?php if ($children): ?>\n          <ul x-ref=\"subnav\" x-show=\"openSub\" x-cloak\n            x-transition:enter=\"motion-safe:transition motion-safe:ease-out motion-safe:duration-150\"\n            x-transition:enter-start=\"opacity-0 translate-y-1\"\n            x-transition:enter-end=\"opacity-100 translate-y-0\"\n            x-transition:leave=\"motion-safe:transition motion-safe:ease-in motion-safe:duration-100\"\n            x-transition:leave-start=\"opacity-100 translate-y-0\"\n            x-transition:leave-end=\"opacity-0 translate-y-1\"\n            class=\"top-full left-0 absolute bg-surface shadow-xl p-2 border border-white/10 rounded-lg min-w-44\">\n            <?php foreach ($children as $child):\n              $childActive = $isExactPage($child);\n            ?>\n              <li>\n                <a href=\"<?= rex_escape($child->getUrl()) ?>\"\n                  class=\"block rounded px-3 py-2 text-sm transition-colors <?= $childActive ? \'text-brand-cyan\' : \'text-muted hover:bg-white/5 hover:text-fg\' ?>\"\n                  <?= $childActive ? \'aria-current=\"page\"\' : \'\' ?>>\n                  <?= rex_escape($child->getName()) ?>\n                </a>\n              </li>\n            <?php endforeach ?>\n          </ul>\n        <?php endif ?>\n      </li>\n    <?php endforeach ?>\n  </ul>\n\n</nav>\n\n<!-- Mobile -->\n<nav x-cloak x-data=\"{ mobileOpen: false }\"\n  @resize.window=\"window.innerWidth >= 768 && (mobileOpen = false)\"\n  x-trap.inert.noscroll.noautofocus=\"mobileOpen\"\n  @keyup.escape.stop.prevent=\"mobileOpen = false\"\n  aria-label=\"Mobile Hauptmenü\" class=\"md:hidden flex items-center gap-3\">\n\n  <!-- Mobile trigger (visible <md) -->\n  <button type=\"button\"\n    @click.prevent.stop=\"mobileOpen = !mobileOpen\"\n    :aria-expanded=\"mobileOpen\"\n    :aria-label=\"mobileOpen ? \'Menü schließen\' : \'Menü öffnen\'\"\n    class=\"right-safe bottom-safe z-30 fixed flex justify-center items-center bg-bg/85 backdrop-blur border border-white/10 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan size-10 text-fg\">\n    <span\n      class=\"sr-only\"\n      x-text=\"mobileOpen ? \'Menü schließen\' : \'Menü öffnen\'\"></span>\n    <span :class=\"mobileOpen ? \'icon-[lucide--x]\' : \'icon-[lucide--menu]\'\" class=\"size-6\" aria-hidden=\"true\"></span>\n  </button>\n\n  <!-- MOBILE drawer (<md) -->\n  <div\n    x-show=\"mobileOpen\"\n    role=\"dialog\" aria-modal=\"true\" aria-label=\"Mobile Hauptmenü\"\n    x-transition:enter=\"transition ease-out duration-300\"\n    x-transition:enter-start=\"translate-x-full\"\n    x-transition:enter-end=\"opacity-100 translate-x-0\"\n    x-transition:leave=\"transition ease-out duration-300\"\n    x-transition:leave-start=\"opacity-100 translate-x-0\"\n    x-transition:leave-end=\"translate-x-full\"\n    class=\"z-20 fixed inset-0 flex flex-col justify-end bg-bg px-8 pt-24 pb-12\">\n    <ul\n      @click.outside.stop=\"mobileOpen = false\"\n      class=\"flex flex-col overflow-y-auto\">\n      <?php foreach ($rootCategories as $top):\n        $children = $top->getChildren();\n        $active = $isActiveBranch($top);\n      ?>\n        <li class=\"py-3 border-white/10 border-b\"\n          <?= $children ? \'x-data=\"{ subOpen: \' . ($isActiveBranch($top) ? \'true\' : \'false\') . \' }\"\' : \'\' ?>>\n          <div class=\"flex justify-between items-center\">\n            <a href=\"<?= rex_escape($top->getUrl()) ?>\"\n              class=\"text-2xl font-bold transition-colors <?= $active ? \'text-brand-cyan\' : \'text-muted hover:text-fg\' ?>\"\n              <?= $active ? \'aria-current=\"page\"\' : \'\' ?>>\n              <?= rex_escape($top->getName()) ?>\n            </a>\n            <?php if ($children): ?>\n              <button type=\"button\" @click=\"subOpen = !subOpen\" :aria-expanded=\"subOpen\"\n                :aria-label=\"subOpen ? \'Untermenü schließen\' : \'Untermenü öffnen\'\"\n                class=\"inline-flex justify-center items-center ml-auto rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-cyan size-8 text-brand-cyan\">\n                <span class=\"size-5 motion-safe:transition-transform icon-[lucide--chevron-down]\" :class=\"subOpen && \'rotate-180\'\" aria-hidden=\"true\"></span>\n              </button>\n            <?php endif ?>\n          </div>\n          <?php if ($children): ?>\n            <ul x-show=\"subOpen\" x-collapse class=\"flex flex-col mt-2 ml-2\">\n              <?php foreach ($children as $child):\n                $childActive = $isExactPage($child);\n              ?>\n                <li>\n                  <a href=\"<?= rex_escape($child->getUrl()) ?>\"\n                    class=\"block py-2 text-base transition-colors <?= $childActive ? \'text-brand-cyan\' : \'text-muted hover:text-fg\' ?>\"\n                    <?= $childActive ? \'aria-current=\"page\"\' : \'\' ?>>\n                    <?= rex_escape($child->getName()) ?>\n                  </a>\n                </li>\n              <?php endforeach ?>\n            </ul>\n          <?php endif ?>\n        </li>\n      <?php endforeach ?>\n    </ul>\n  </div>\n\n</nav>',	0,	'2026-03-06 17:22:39',	'admin',	'2026-05-01 10:34:34',	'console',	'{\"ctype\":[],\"modules\":{\"1\":{\"all\":\"1\"}},\"categories\":{\"all\":\"1\"}}',	0);

