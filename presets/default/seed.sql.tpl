INSERT INTO `rex_module` (`id`, `key`, `name`, `output`, `input`, `createdate`, `createuser`, `updatedate`, `updateuser`, `attributes`, `revision`) VALUES
(1,	'hero',	'Hero',	'<!-- Hero -->\r\n<section>\r\n	<p class=\"font-semibold text-brand-cyan text-sm uppercase tracking-widest\">\r\n		Powered by REDAXO · Built with Vite 8\r\n	</p>\r\n	<h1 class=\"mt-4 font-extrabold text-fg leading-[0.95] tracking-tight clamp-[text,6xl,9xl]\">\r\n		Build <span class=\"inline-block w-fit text-gradient-brand\">faster</span>.<br>\r\n		Ship <span class=\"inline-block w-fit text-gradient-brand\">better</span>.\r\n	</h1>\r\n	<p class=\"mt-8 max-w-prose text-muted clamp-[text,lg,xl]\">\r\n		ViteRex bringt Vite in REDAXO. HMR, Live-Reload bei Inhaltsänderungen,\r\n		Tailwind 4 und ein manifest-bewusster Asset-Helper — alles vorkonfiguriert.\r\n	</p>\r\n	<div class=\"flex flex-wrap gap-3 mt-10\">\r\n		<a href=\"https://github.com/ynamite/viterex_addon\" class=\"btn-primary\" rel=\"noopener\">\r\n			Get started\r\n		</a>\r\n		<a href=\"#features\" class=\"btn-ghost\">Features ansehen</a>\r\n	</div>\r\n</section>',	'',	'2026-04-30 16:09:33',	'admin',	'2026-04-30 21:42:29',	'console',	NULL,	0),
